# ──────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT — .env.development
# Copy this file to .env.development and fill in your local values.
# This file is safe to commit (no real secrets).
# .env.development itself is gitignored — never commit it.
# ──────────────────────────────────────────────────────────────────

APP_ENV=development
DEBUG=True

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-random-hex-string-for-local-dev

# SQLite is used automatically when APP_ENV=development.
# You can also point to a local PostgreSQL DB for dev — optional.
# DATABASE_URL=postgresql://postgres:password@localhost:5432/skillbasehire_dev

# Email — leave commented out to skip email sending locally
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your-app-password
