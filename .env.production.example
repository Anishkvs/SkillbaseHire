# ──────────────────────────────────────────────────────────────────
# PRODUCTION ENVIRONMENT — .env.production
# Set these as environment variables in the DigitalOcean production app.
# Do NOT commit .env.production — it is gitignored.
# This example file is safe to commit (no real secrets).
# ──────────────────────────────────────────────────────────────────

APP_ENV=production
DEBUG=False

# Production secret key — must be long, random, and kept confidential.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-strong-production-secret-key

# Production PostgreSQL database — NEVER share or reuse this in staging/dev.
# On DigitalOcean: attach the production database component.
# The platform injects DATABASE_URL automatically when a DB is attached.
DATABASE_URL=postgresql://user:password@prod-db-host:5432/skillbasehire_production

# Email — use the real transactional email account
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@skillbasehire.com
SMTP_PASS=your-production-app-password
