# ──────────────────────────────────────────────────────────────────
# STAGING ENVIRONMENT — .env.staging
# Set these as environment variables in the DigitalOcean staging app.
# Do NOT commit .env.staging — it is gitignored.
# This example file is safe to commit (no real secrets).
# ──────────────────────────────────────────────────────────────────

APP_ENV=staging
DEBUG=False

# Generate a fresh secret key for staging — different from production.
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-staging-secret-key

# Staging PostgreSQL database — MUST be separate from production.
# On DigitalOcean: attach a separate "staging-db" database component.
# The platform injects DATABASE_URL automatically when a DB is attached.
DATABASE_URL=postgresql://user:password@staging-db-host:5432/skillbasehire_staging

# Email — use a test account or leave commented out
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=staging-test@email.com
# SMTP_PASS=your-app-password
